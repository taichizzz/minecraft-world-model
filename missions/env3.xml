<?xml version="1.0" encoding="UTF-8"?>
<Mission xmlns="http://ProjectMalmo.microsoft.com"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <About>
    <Summary>Dataset Collection - Env3 (Env2 + Floor Obstacles)</Summary>
  </About>

  <ServerSection>
    <ServerHandlers>
      <FlatWorldGenerator generatorString="3;7,220*1,5*3,2;3;,biome_1"/>

      <DrawingDecorator>
        <!-- Floor -->
        <DrawCuboid x1="-5" y1="226" z1="-5" x2="5" y2="226" z2="5" type="stone"/>

        <!-- Main walls -->
        <DrawCuboid x1="-5" y1="227" z1="-5" x2="5" y2="230" z2="-5" type="cobblestone"/>
        <DrawCuboid x1="-5" y1="227" z1="5"  x2="5" y2="230" z2="5"  type="planks"/>
        <DrawCuboid x1="-5" y1="227" z1="-5" x2="-5" y2="230" z2="5" type="brick_block"/>
        <DrawCuboid x1="5"  y1="227" z1="-5" x2="5"  y2="230" z2="5" type="glass"/>

        <!-- Secondary sprinkled blocks (same as env2) -->
        <DrawBlock x="-3" y="227" z="-5" type="mossy_cobblestone"/>
        <DrawBlock x="2"  y="228" z="-5" type="mossy_cobblestone"/>
        <DrawBlock x="-1" y="229" z="-5" type="mossy_cobblestone"/>
        <DrawBlock x="4"  y="230" z="-5" type="mossy_cobblestone"/>
        <DrawBlock x="0"  y="227" z="-5" type="mossy_cobblestone"/>

        <DrawBlock x="-4" y="228" z="5" type="spruce_planks"/>
        <DrawBlock x="-1" y="229" z="5" type="spruce_planks"/>
        <DrawBlock x="1"  y="227" z="5" type="spruce_planks"/>
        <DrawBlock x="3"  y="230" z="5" type="spruce_planks"/>
        <DrawBlock x="5"  y="228" z="5" type="spruce_planks"/>

        <DrawBlock x="-5" y="227" z="-2" type="stonebrick"/>
        <DrawBlock x="-5" y="228" z="1"  type="stonebrick"/>
        <DrawBlock x="-5" y="229" z="3"  type="stonebrick"/>
        <DrawBlock x="-5" y="230" z="-4" type="stonebrick"/>
        <DrawBlock x="-5" y="228" z="5"  type="stonebrick"/>

        <DrawBlock x="5" y="227" z="-3" type="stained_glass"/>
        <DrawBlock x="5" y="228" z="-1" type="stained_glass"/>
        <DrawBlock x="5" y="229" z="2"  type="stained_glass"/>
        <DrawBlock x="5" y="230" z="4"  type="stained_glass"/>
        <DrawBlock x="5" y="228" z="0"  type="stained_glass"/>

        <!-- Obstacles on floor (y=227) -->
        <!-- Use visually distinct blocks -->
        <DrawBlock x="-2" y="227" z="-1" type="obsidian"/>
        <DrawBlock x="-1" y="227" z="2"  type="obsidian"/>
        <DrawBlock x="2"  y="227" z="1"  type="obsidian"/>

        <DrawBlock x="-3" y="227" z="0"  type="nether_brick"/>
        <DrawBlock x="0"  y="227" z="3"  type="nether_brick"/>

        <DrawBlock x="1"  y="227" z="-2" type="quartz_block"/>
        <DrawBlock x="3"  y="227" z="-1" type="quartz_block"/>

        <DrawBlock x="-2" y="227" z="3"  type="end_stone"/>
        <DrawBlock x="3"  y="227" z="2"  type="end_stone"/>
        <DrawBlock x="-1" y="227" z="-3" type="end_stone"/>

        <!-- Goal + landmarks -->
        <DrawBlock x="4"  y="227" z="4"  type="diamond_block"/>
        <DrawBlock x="-4" y="227" z="4"  type="gold_block"/>
        <DrawBlock x="4"  y="227" z="-4" type="emerald_block"/>
      </DrawingDecorator>

      <ServerQuitFromTimeUp timeLimitMs="30000"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>Collector</Name>

    <AgentStart>
      <Placement x="2.5" y="227" z="-2.5" yaw="45" pitch="15"/>
    </AgentStart>

    <AgentHandlers>
      <ObservationFromFullStats/>
      <ObservationFromRay/>

      <VideoProducer>
        <Width>64</Width>
        <Height>64</Height>
      </VideoProducer>

      <DiscreteMovementCommands/>

      <AgentQuitFromTouchingBlockType>
        <Block type="diamond_block"/>
      </AgentQuitFromTouchingBlockType>
    </AgentHandlers>
  </AgentSection>

</Mission>