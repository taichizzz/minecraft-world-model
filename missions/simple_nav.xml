<?xml version="1.0" encoding="UTF-8"?>
<Mission xmlns="http://ProjectMalmo.microsoft.com"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <About>
    <Summary>Dataset Collection - Simple Room</Summary>
  </About>

  <ServerSection>
    <ServerHandlers>
      <!-- Flat void-ish world at y~226 -->
      <FlatWorldGenerator generatorString="3;7,220*1,5*3,2;3;,biome_1"/>

      <DrawingDecorator>
        <DrawCuboid x1="-5" y1="226" z1="-5" x2="5" y2="226" z2="5" type="stone"/>

        <!-- Walls (4 different materials for visual diversity) -->
        <!-- North wall (z = -5) -->
        <DrawCuboid x1="-5" y1="227" z1="-5" x2="5" y2="230" z2="-5" type="cobblestone"/>
        <!-- South wall (z = 5) -->
        <DrawCuboid x1="-5" y1="227" z1="5" x2="5" y2="230" z2="5" type="planks"/>
        <!-- West wall (x = -5) -->
        <DrawCuboid x1="-5" y1="227" z1="-5" x2="-5" y2="230" z2="5" type="brick_block"/>
        <!-- East wall (x = 5) -->
        <DrawCuboid x1="5" y1="227" z1="-5" x2="5" y2="230" z2="5" type="glass"/>

        <!-- Goal -->
        <DrawBlock x="4" y="227" z="4" type="diamond_block"/>

        <!-- Add a couple extra landmarks so frames aren't repetitive -->
        <DrawBlock x="-4" y="227" z="4" type="gold_block"/>
        <DrawBlock x="4" y="227" z="-4" type="emerald_block"/>
      </DrawingDecorator>

      <!-- End the mission if time is up -->
      <ServerQuitFromTimeUp timeLimitMs="30000"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>Collector</Name>

    <AgentStart>
      <Placement x="0.5" y="227" z="0.5" yaw="-45" pitch="40"/>
    </AgentStart>

    <AgentHandlers>
      <ObservationFromFullStats/>
      <ObservationFromRay/>

      <VideoProducer>
        <Width>64</Width>
        <Height>64</Height>
      </VideoProducer>

      <DiscreteMovementCommands/>

      
      <AgentQuitFromTouchingBlockType>
        <Block type="diamond_block"/>  <!-- Terminal condition: stop when touching diamond -->
      </AgentQuitFromTouchingBlockType>
    </AgentHandlers>
  </AgentSection>

</Mission>
