<?xml version="1.0" encoding="UTF-8"?>
<Mission xmlns="http://ProjectMalmo.microsoft.com"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <About>
    <Summary>Env4 Corridor (seed 20264412) - diamond goal + cyan wool pillars</Summary>
  </About>

  <ServerSection>
    <ServerHandlers>
      <FlatWorldGenerator generatorString="3;7,220*1,5*3,2;3;,biome_1"/>

      <DrawingDecorator>
        <!-- Corridor floor (gold) -->
        <DrawCuboid x1="-10" y1="226" z1="-2" x2="10" y2="226" z2="2" type="gold_block"/>

        <!-- Side walls (brick) at z = -2 and z = 2, trimmed from x=-9..9 -->
        <DrawCuboid x1="-9" y1="227" z1="-2" x2="9" y2="229" z2="-2" type="brick_block"/>
        <DrawCuboid x1="-9" y1="227" z1="2"  x2="9" y2="229" z2="2"  type="brick_block"/>

        <!-- End caps (brick) at x = -10 and x = 10 -->
        <DrawCuboid x1="-10" y1="227" z1="-2" x2="-10" y2="229" z2="2" type="brick_block"/>
        <DrawCuboid x1="10"  y1="227" z1="-2" x2="10"  y2="229" z2="2" type="brick_block"/>

        <!-- Diamond goal at far end (x2-1, wallY1, cz) => (9, 227, 0) -->
        <DrawBlock x="9" y="227" z="0" type="diamond_block"/>

        <!-- Seeded random 1x1 cyan wool pillars (height 3: y=227..229) -->
        <DrawCuboid x1="1"  y1="227" z1="0" x2="1"  y2="229" z2="0" type="cyan_wool"/>
        <DrawCuboid x1="-6" y1="227" z1="1" x2="-6" y2="229" z2="1" type="cyan_wool"/>
        <DrawCuboid x1="-3" y1="227" z1="1" x2="-3" y2="229" z2="1" type="cyan_wool"/>
        <DrawCuboid x1="3"  y1="227" z1="1" x2="3"  y2="229" z2="1" type="cyan_wool"/>
        <DrawCuboid x1="-4" y1="227" z1="1" x2="-4" y2="229" z2="1" type="cyan_wool"/>
      </DrawingDecorator>

      <ServerQuitFromTimeUp timeLimitMs="30000"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>Collector</Name>

    <AgentStart>
      <Placement x="-9.5" y="227" z="0.5" yaw="90" pitch="20"/>
    </AgentStart>

    <AgentHandlers>
      <ObservationFromFullStats/>
      <ObservationFromRay/>

      <VideoProducer>
        <Width>64</Width>
        <Height>64</Height>
      </VideoProducer>

      <DiscreteMovementCommands/>

      <AgentQuitFromTouchingBlockType>
        <Block type="diamond_block"/>
      </AgentQuitFromTouchingBlockType>
    </AgentHandlers>
  </AgentSection>

</Mission>