<?xml version="1.0" encoding="UTF-8"?>
<Mission xmlns="http://ProjectMalmo.microsoft.com"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <About>
    <Summary>Env6 T-Junction (seed 11144314) - diamond bottom + cyan pillars</Summary>
  </About>

  <ServerSection>
    <ServerHandlers>
      <FlatWorldGenerator generatorString="3;7,220*1,5*3,2;3;,biome_1"/>

      <DrawingDecorator>
        <!-- =========================
             FLOOR (gold) = union of:
             Stem: x=-2..2, z=-12..0
             Bar : x=-10..10, z=-2..2
             ========================= -->

        <!-- Stem floor -->
        <DrawCuboid x1="-2" y1="226" z1="-12" x2="2" y2="226" z2="0" type="gold_block"/>
        <!-- Bar floor -->
        <DrawCuboid x1="-10" y1="226" z1="-2" x2="10" y2="226" z2="2" type="gold_block"/>

        <!-- =========================
             WALLS (bricks) height y=227..229
             ========================= -->

        <!-- Stem side walls (x=-2 and x=2), z=-11..-1 -->
        <DrawCuboid x1="-2" y1="227" z1="-11" x2="-2" y2="229" z2="-1" type="brick_block"/>
        <DrawCuboid x1="2"  y1="227" z1="-11" x2="2"  y2="229" z2="-1" type="brick_block"/>

        <!-- Stem bottom cap at z=-12, x=-2..2 -->
        <DrawCuboid x1="-2" y1="227" z1="-12" x2="2" y2="229" z2="-12" type="brick_block"/>

        <!-- Bar walls at z=-2 and z=2 (trimmed x=-9..9) -->
        <DrawCuboid x1="-9" y1="227" z1="-2" x2="9" y2="229" z2="-2" type="brick_block"/>
        <DrawCuboid x1="-9" y1="227" z1="2"  x2="9" y2="229" z2="2"  type="brick_block"/>

        <!-- Bar end caps at x=-10 and x=10, z=-2..2 -->
        <DrawCuboid x1="-10" y1="227" z1="-2" x2="-10" y2="229" z2="2" type="brick_block"/>
        <DrawCuboid x1="10"  y1="227" z1="-2" x2="10"  y2="229" z2="2" type="brick_block"/>

        <!-- "Close BOTH openings of the bar" (redundant in JS but included for exactness) -->
        <DrawCuboid x1="-10" y1="227" z1="-2" x2="10" y2="229" z2="-2" type="brick_block"/>
        <DrawCuboid x1="-10" y1="227" z1="2"  x2="10" y2="229" z2="2"  type="brick_block"/>

        <!-- =========================
             CARVE (air) to match:
             /fill x=-2..2 y=227..229 z=-2..1 air replace bricks
             ========================= -->
        <DrawCuboid x1="-2" y1="227" z1="-2" x2="2" y2="229" z2="1" type="air"/>

        <!-- =========================
             DIAMOND GOAL (only must-have)
             goalX=cx=0, goalZ=zStemStart+1=-11
             ========================= -->
        <DrawBlock x="0" y="227" z="-11" type="diamond_block"/>

        <!-- =========================
             Seeded cyan wool pillars (height 3: y=227..229)
             Computed from your JS seed 11144314
             ========================= -->
        <DrawCuboid x1="-1" y1="227" z1="-8"  x2="-1" y2="229" z2="-8"  type="cyan_wool"/>
        <DrawCuboid x1="-1" y1="227" z1="-6"  x2="-1" y2="229" z2="-6"  type="cyan_wool"/>
        <DrawCuboid x1="0"  y1="227" z1="-10" x2="0"  y2="229" z2="-10" type="cyan_wool"/>
        <DrawCuboid x1="6"  y1="227" z1="1"   x2="6"  y2="229" z2="1"   type="cyan_wool"/>
        <DrawCuboid x1="-6" y1="227" z1="0"   x2="-6" y2="229" z2="0"   type="cyan_wool"/>
        <DrawCuboid x1="-3" y1="227" z1="0"   x2="-3" y2="229" z2="0"   type="cyan_wool"/>
        <DrawCuboid x1="0"  y1="227" z1="-6"  x2="0"  y2="229" z2="-6"  type="cyan_wool"/>
      </DrawingDecorator>

      <ServerQuitFromTimeUp timeLimitMs="30000"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>Collector</Name>

    <AgentStart>
      <Placement x="-9.5" y="227" z="0.5" yaw="90" pitch="20"/>
    </AgentStart>

    <AgentHandlers>
      <ObservationFromFullStats/>
      <ObservationFromRay/>

      <VideoProducer>
        <Width>64</Width>
        <Height>64</Height>
      </VideoProducer>

      <DiscreteMovementCommands/>

      <AgentQuitFromTouchingBlockType>
        <Block type="diamond_block"/>
      </AgentQuitFromTouchingBlockType>
    </AgentHandlers>
  </AgentSection>

</Mission>